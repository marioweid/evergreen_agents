# OpenAI API key (agents + embeddings)
OPENAI_API_KEY=your-openai-api-key-here

# Database (overrides docker-compose default when running locally)
DATABASE_URL=postgresql://evergreen:evergreen@localhost:5432/evergreen

# Agent service public hostname (used in A2A agent card URL)
PUBLIC_HOST=localhost

# Pipeline schedule — cron expression (default: every Sunday at 02:00)
# PIPELINE_CRON=0 2 * * 0

# Set to false to skip the immediate run on container startup
# RUN_ON_STARTUP=true

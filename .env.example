# ── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://evergreen:evergreen@localhost:5432/evergreen
OPENAI_API_KEY=sk-...

# ── Google Drive — pipeline (service account, read-only) ─────────────────
# Path to the service account JSON key file used to read customer folders.
GOOGLE_SA_KEY_PATH=sa_drive_agent.json
# ID of the root Drive folder that contains one subfolder per customer.
GOOGLE_DRIVE_CUSTOMER_FOLDER_ID=

# ── Google Drive — agent (OAuth user credentials, write) ─────────────────
# Path to token.json produced by scripts/setup_drive_auth.py.
# Required only if you want the report agent to save reports back to Drive.
GOOGLE_OAUTH_TOKEN_PATH=token.json

# ── Pipeline schedule (cron expressions) ─────────────────────────────────
# M365 roadmap ingestion — default: every Sunday at 02:00
PIPELINE_CRON=0 2 * * 0
# Google Drive customer sync — default: every day at 03:00
DRIVE_SYNC_CRON=0 3 * * *
# Run both jobs once immediately on pipeline startup
RUN_ON_STARTUP=true

# ── Agent server ─────────────────────────────────────────────────────────
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
